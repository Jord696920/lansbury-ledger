# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public app URL (used by api-guard same-origin check).
# Set this to your production URL so API-route guards allow its host.
NEXT_PUBLIC_APP_URL=https://lansbury-ledger.vercel.app

# Anthropic (for AI features)
ANTHROPIC_API_KEY=your-anthropic-api-key

# SMTP (for invoice emails — optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
